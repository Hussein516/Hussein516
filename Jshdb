local Players = game:GetService("Players")
local Lighting = game:GetService("Lighting")
local Workspace = game:GetService("Workspace")

pcall(function() settings().Rendering.QualityLevel = 1 end)
pcall(function() Lighting.GlobalShadows = false Lighting.FogEnd = 9e9 Lighting.Brightness = 1 end)
pcall(function() Workspace.Terrain.WaterWaveSize = 0 Workspace.Terrain.WaterWaveSpeed = 0 Workspace.Terrain.WaterReflectance = 0 Workspace.Terrain.WaterTransparency = 0 end)

local function isPlayer(obj)
	local current = obj.Parent
	while current and current ~= Workspace do
		if current:IsA("Model") and Players:GetPlayerFromCharacter(current) then return true end
		if current:IsA("Accessory") or current:IsA("Tool") or current:IsA("Shirt") or current:IsA("Pants") or current:IsA("Humanoid") then return true end
		current = current.Parent
	end
	return false
end

local function clean(obj)
	if not obj or not obj.Parent then return end
	
	if obj:IsA("Texture") or obj:IsA("Decal") or obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Beam") or obj:IsA("Smoke") or obj:IsA("Fire") or obj:IsA("Sparkles") or obj:IsA("PostEffect") or obj:IsA("Atmosphere") or obj:IsA("Clouds") then
		pcall(function() obj:Destroy() end)
	elseif obj:IsA("BasePart") then
		if not isPlayer(obj) then
			pcall(function()
				obj.Material = Enum.Material.SmoothPlastic
				obj.Reflectance = 0
				obj.CastShadow = false
				if obj:IsA("MeshPart") then obj.TextureID = "" end
			end)
		end
	elseif obj:IsA("SpecialMesh") then
		if not isPlayer(obj) then
			pcall(function() obj.TextureId = "" end)
		end
	end
end

local elements = Workspace:GetDescendants()
for i = 1, #elements do
	clean(elements[i])
end

table.clear(elements)
elements = nil

if gcinfo then
	pcall(function() collectgarbage("collect") end)
end
