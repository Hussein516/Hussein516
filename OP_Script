BtnVoidTrap.MouseButton1Click:Connect(function()
    if stateVoidTrap then return end
    local myHRP = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not myHRP then return end
    stateVoidTrap = true; resetStatesExcept("VoidTrap")
    savedPosition = myHRP.CFrame; trapStartTime = os.clock()
    BtnVoidTrap.Text = "⚡ الإعصار نشط (5 ثوانٍ)..."; BtnVoidTrap.BackgroundColor3 = Color3.fromRGB(255, 0, 50)
