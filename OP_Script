table.insert(conns, UserInputService.InputChanged:Connect(function(input)
    if (stateBehind or stateWave or stateUnder or stateAntiBack or stateVoidTrap) and (input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseMovement) then
        cameraX = cameraX - (input.Delta.X * 0.4); cameraY = math_clamp(cameraY - (input.Delta.Y * 0.4), -75, 75)
    end
end))

table.insert(conns, RunService.Stepped:Connect(function()
    local char = LocalPlayer.Character
    if not char then return end
    local myHRP = char:FindFirstChild("HumanoidRootPart")
    
    if stateUnder or stateVoidTrap or stateAntiBack or (targetPlayer and isTargetRagdoll(targetPlayer)) then
        for _, p in pairs(char:GetChildren()) do if p:IsA("BasePart") then p.CanCollide = false end end
    end
    
    if myHRP and stateVoidTrap then myHRP.CanCollide = true end
    
    if not stateVoidTrap then
        if myHRP and myHRP.Anchored then myHRP.Anchored = false end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then hum.PlatformStand = false; hum.Sit = false end
    end
end))

-- [ محرك الرندرة الأساسي ونظام الفحص المدمج كلياً ]
table.insert(conns, RunService.RenderStepped:Connect(function(deltaTime)
    local myChar = LocalPlayer.Character
    if not myChar then return end
    local myHRP, myHum = myChar:FindFirstChild("HumanoidRootPart"), myChar:FindFirstChildOfClass("Humanoid")
    if not myHRP or not myHum then return end
    myHum.RequiresNeck = false 

    local absoluteMinY = Barrier.Position.Y + 1.5
    if myHRP.Position.Y < absoluteMinY and not stateVoidTrap then
        myHRP.Velocity = Vector3_new(0, 0, 0); myHRP.CFrame = CFrame_new(myHRP.Position.X, absoluteMinY + 3.0, myHRP.Position.Z)
    end

    if stateVoidTrap then
        if os.clock() - trapStartTime < 5 then
            setSmartFreeze(true)
            spinAngle = (spinAngle + 30000 * deltaTime) % 360
            local fixedVoidPos = Vector3_new(savedPosition.X, workspace.FallenPartsDestroyHeight + 1.2, savedPosition.Z)
            myHRP.CFrame = CFrame_new(fixedVoidPos) * CFrame_Angles(math_rad(-90), math_rad(spinAngle), 0)
            myHRP.Velocity = Vector3_new(0, 0, 0); myHRP.RotVelocity = Vector3_new(0, 99999, 0); myHRP.Anchored = true
        else
            stateVoidTrap = false; myHRP.Anchored = false
            if savedPosition then myHRP.CFrame = savedPosition end
            setSmartFreeze(false)
            BtnVoidTrap.Text = "💀 إعصار النوم المغزلي القاتل (5S)"; BtnVoidTrap.BackgroundColor3 = Color3.fromRGB(160, 15, 40)
        end
        return 
    end

    if not targetPlayer or not targetPlayer.Character then targetPlayer = getTarget() end
    
    if targetPlayer and targetPlayer.Character and targetPlayer.Character:FindFirstChild("HumanoidRootPart") then
        local targetHRP = targetPlayer.Character.HumanoidRootPart
        local velocity = targetHRP.Velocity
        targetAcceleration = (velocity - lastTargetVelocity) / math.max(deltaTime, 0.001)
        lastTargetVelocity = velocity
        if targetAcceleration.Magnitude > 150 then targetAcceleration = targetAcceleration.Unit * 150 end
        local predictedPos = targetHRP.Position + (velocity * PREDICTION_TIME + 0.5 * targetAcceleration * (PREDICTION_TIME ^ 2))

        local autoDef = false
        local chosenDist = -5.0

        local liveFolder = workspace:FindFirstChild("Live")
        if liveFolder then
            local targetFolder = liveFolder:FindFirstChild(targetPlayer.Name)
            if targetFolder then
                local firstTool = ""
                local bp = targetPlayer:FindFirstChild("Backpack")
                if bp and bp:GetChildren()[1] and bp:GetChildren()[1]:IsA("Tool") then
                    firstTool = bp:GetChildren()[1].Name
                end

                -- تحديد إذا كانت الشخصية مميزة تفحص أول أداة لها
                local isSpecialCharacter = (firstTool == "Weboom" or firstTool == "Doom Dive" or firstTool == "Bullet Barrage" or firstTool == "Machine Gun Blows" or firstTool == "Crushing Pull")

                local hasFreeze = targetFolder:FindFirstChild("Freeze") ~= nil
                local hasSlowed = targetFolder:FindFirstChild("Slowed") ~= nil
                local hasGrabWep = targetFolder:FindFirstChild("GrabWeapon") ~= nil
                local hasBackpack = targetFolder:FindFirstChild("BackpackOpen") ~= nil
                local hasGreen = targetFolder:FindFirstChild("GreenAura") ~= nil
                local hasFree = targetFolder:FindFirstChild("free") ~= nil
                local hasHunter = targetFolder:FindFirstChild("HunterCounter") ~= nil

                -- شروط تفعيل كائن Freeze المقيدة بالكامل واستثناء Weboom ليصبح دائماً شغالاً
                local freezeOK = false
                if firstTool == "Weboom" then
                    if hasFreeze then freezeOK = true end
                elseif isSpecialCharacter and hasFreeze then
                    if hasGrabWep or hasBackpack then
                        freezeOK = true
                    end
                end

                local defenseTriggered = false

                -- استثناء مهارة Machine Gun Blows (فقط Freeze و Slowed يعملان)
                if firstTool == "Machine Gun Blows" then
                    if freezeOK or hasSlowed then
                        defenseTriggered = true
                    end
                else
                    -- الفحص العام المعتاد لبقية الأدوار والشخصيات
                    local stdObjs = hasSlowed or targetFolder:FindFirstChild("ProjectileCounter") or 
                                    targetFolder:FindFirstChild("HunterFists") or targetFolder:FindFirstChild("NoBlock") or 
                                    targetFolder:FindFirstChild("NoPunch") or targetFolder:FindFirstChild("NoDash") or 
                                    targetFolder:FindFirstChild("BarrageBind") or targetFolder:FindFirstChild("HiddenFist") or 
                                    targetFolder:FindFirstChild("AtomicCounter") or targetFolder:FindFirstChild("BodyGyroBind")

                    if stdObjs or freezeOK or hasGreen then
                        defenseTriggered = true; chosenDist = -10.0
                    end
                end

                -- تفعيل وضع الحماية والمسافات الاستثنائية الحتمية
                if defenseTriggered then
                    autoDef = true
                end
                
                if hasHunter then 
                    autoDef = true; chosenDist = -13.0 
                end
                if hasFreeze and hasBackpack then 
                    autoDef = true; chosenDist = (firstTool == "Weboom") and -30.0 or -20.0
                end
                if hasFree and firstTool == "Doom Dive" then 
                    autoDef = true; chosenDist = -20.0 
                end
            end
        end

        if (stateBehind or stateWave or stateUnder or stateAntiBack) and isTargetRagdoll(targetPlayer) then
            setSmartFreeze(true)
            myHRP.CFrame = CFrame.lookAt(predictedPos - Vector3_new(0, 3.5, 0), predictedPos)
        else
            if stateBehind then
                setSmartFreeze(true)
                myHRP.CFrame = CFrame.lookAt(predictedPos + (targetHRP.CFrame.LookVector * (autoDef and chosenDist or -5.0)), predictedPos)
            elseif stateWave then
                setSmartFreeze(true)
                if not autoDef then
                    loopTime = loopTime + 0.67
                    chosenDist = -(1.0 + (((math_sin(loopTime) + 1) / 2) * 4.0))
                end
                myHRP.CFrame = CFrame.lookAt(predictedPos + (targetHRP.CFrame.LookVector * chosenDist), predictedPos)
            elseif stateUnder then
                setSmartFreeze(true)
                myHRP.CFrame = CFrame.lookAt(predictedPos - Vector3_new(0, 3.5, 0), predictedPos)
            elseif stateAntiBack then
                setSmartFreeze(true)
                loopTime = loopTime + deltaTime * 65
                local finalPos = predictedPos + (targetHRP.CFrame.LookVector * (autoDef and chosenDist or -3.2)) + (targetHRP.CFrame.RightVector * (math_sin(loopTime) * 3.2))
                myHRP.CFrame = CFrame.lookAt(finalPos, predictedPos)
                myHRP.Velocity = targetHRP.CFrame.RightVector * (math_cos(loopTime) * 15)
            else
                if not stateBehind and not stateWave then setSmartFreeze(false) end
            end
        end
        
        if stateBehind or stateWave or stateUnder or stateAntiBack then
            myHum.AutoRotate = false; Camera.CameraType = Enum.CameraType.Scriptable
            Camera.CFrame = CFrame_new(targetHRP.Position + Vector3_new(0, 2, 0)) * (CFrame_Angles(0, math_rad(cameraX), 0) * CFrame_Angles(math_rad(cameraY), 0, 0)) * CFrame_new(0, 0, cameraZoom)
        end
    else
        if not stateBehind and not stateWave and not stateUnder and not stateAntiBack and Camera.CameraType == Enum.CameraType.Scriptable then
            Camera.CameraType = Enum.CameraType.Custom; myHum.AutoRotate = true
        end
        setSmartFreeze(false)
    end
end))
