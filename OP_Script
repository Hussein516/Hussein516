-- [ المتغيرات الأساسية للمحرك ]
local targetPlayer = nil
local stateBehind, stateWave, stateUnder, stateAntiBack, stateVoidTrap, stateFPS = false, false, false, false, false, false
local savedPosition = nil
local trapStartTime, spinAngle = 0, 0
local PREDICTION_TIME = 0.28
local lastTargetVelocity, targetAcceleration = Vector3_new(), Vector3_new()
local cameraX, cameraY, cameraZoom, loopTime = 0, 0, 11, 0

ToggleBtn.MouseButton1Click:Connect(function()
    MainFrame.Visible = not MainFrame.Visible
    ToggleBtn.Text = MainFrame.Visible and "⚡ [ CLOSE ]" or "⚡ [ OPEN ]"
    ToggleBtn.TextColor3 = MainFrame.Visible and Color3.fromRGB(255, 60, 60) or Color3.fromRGB(0, 255, 180)
end)

local function isTargetRagdoll(target)
    if not target or not target.Character then return false end
    local humanoid = target.Character:FindFirstChildOfClass("Humanoid")
    local hrp = target.Character:FindFirstChild("HumanoidRootPart")
    return humanoid and hrp and (humanoid.PlatformStand or humanoid.Sit or (hrp.Velocity.Magnitude > 0.05 and humanoid.WalkSpeed == 0))
end

local function getTarget()
    local text = NameInput.Text:lower()
    if text == "" then return nil end
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and (p.Name:lower():find(text) or p.DisplayName:lower():find(text)) then return p end
    end
    return nil
end

local function setSmartFreeze(freeze)
    local char = LocalPlayer.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end
    if char:FindFirstChild("Animate") then char.Animate.Disabled = freeze end
    local animator = hum:FindFirstChildOfClass("Animator") or hum
    for _, track in pairs(animator:GetPlayingAnimationTracks()) do track:AdjustSpeed(freeze and 0 or 1) end
    hum.WalkSpeed = freeze and 0 or 16
end

local function resetStatesExcept(activeState)
    stateBehind = (activeState == "Behind") and stateBehind or false
    stateWave = (activeState == "Wave") and stateWave or false
    stateUnder = (activeState == "Under") and stateUnder or false
    stateAntiBack = (activeState == "AntiBack") and stateAntiBack or false
    if activeState ~= "VoidTrap" then stateVoidTrap = false; BtnVoidTrap.Text = "💀 إعصار النوم المغزلي القاتل (5S)"; BtnVoidTrap.BackgroundColor3 = Color3.fromRGB(160, 15, 40) end

    BtnBehind.Text = stateBehind and "🔒 تثبيت عادي: مفعل" or "🔒 تثبيت عادي: مطفأ"
    BtnBehind.BackgroundColor3 = stateBehind and Color3.fromRGB(0, 140, 255) or Color3.fromRGB(20, 20, 25)
    BtnWave.Text = stateWave and "🌊 تثبيت تدريجي: مفعل" or "🌊 تثبيت تدريجي: مطفأ"
    BtnWave.BackgroundColor3 = stateWave and Color3.fromRGB(0, 140, 255) or Color3.fromRGB(20, 20, 25)
    BtnUnder.Text = stateUnder and "👇 تثبيت أرضي: مفعل" or "👇 تثبيت أرضي (3.5S): مطفأ"
    BtnUnder.BackgroundColor3 = stateUnder and Color3.fromRGB(255, 140, 0) or Color3.fromRGB(20, 20, 25)
    BtnAntiBack.Text = stateAntiBack and "⚔️ ضد الهكر الخلفي: مفعل" or "⚔️ ضد الهكر الخلفي: مطفأ"
    BtnAntiBack.BackgroundColor3 = stateAntiBack and Color3.fromRGB(0, 180, 100) or Color3.fromRGB(20, 20, 25)
    
    if not stateBehind and not stateWave and not stateUnder and not stateAntiBack and not stateVoidTrap then
        Camera.CameraType = Enum.CameraType.Custom
        if LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid") then LocalPlayer.Character:FindFirstChildOfClass("Humanoid").AutoRotate = true end
        setSmartFreeze(false)
    end
end

BtnBehind.MouseButton1Click:Connect(function() stateBehind = not stateBehind; resetStatesExcept("Behind"); targetPlayer = getTarget() end)
BtnWave.MouseButton1Click:Connect(function() stateWave = not stateWave; resetStatesExcept("Wave"); targetPlayer = getTarget() end)
BtnUnder.MouseButton1Click:Connect(function() stateUnder = not stateUnder; resetStatesExcept("Under"); targetPlayer = getTarget() end)
