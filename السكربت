RunService.RenderStepped:Connect(function(deltaTime)
    local myCharacter = LocalPlayer.Character
    if not myCharacter then return end
    local myHRP = myCharacter:FindFirstChild("HumanoidRootPart")
    local myHumanoid = myCharacter:FindFirstChildOfClass("Humanoid")
    if not myHRP or not myHumanoid then return end

    if myHumanoid.RequiresNeck then myHumanoid.RequiresNeck = false end 
    if myHRP.Position.Y < (workspace.FallenPartsDestroyHeight + 2) then
        myHRP.Velocity = Vector3.new(0, 0, 0)
        myHRP.CFrame = CFrame.new(myHRP.Position.X, workspace.FallenPartsDestroyHeight + 5, myHRP.Position.Z)
    end

    if stateFPS and setfpscap then setfpscap(9999999) end

    if stateVoidTrap then
        local elapsedTime = os.clock() - trapStartTime
        if elapsedTime < 5 then
            setSmartFreeze(true)
            spinAngle = (spinAngle + 1000000000000000000000 * deltaTime) % 360
            local voidCFrame = CFrame.new(myHRP.Position.X, voidYThreshold, myHRP.Position.Z) 
                               * CFrame.Angles(math.rad(90), 0, 0) 
                               * CFrame.Angles(0, math.rad(spinAngle), 0) 
            myHRP.CFrame = voidCFrame
            myHRP.Velocity = Vector3.new(0, 0, 0)
            myHRP.RotVelocity = Vector3.new(0, 1000000, 0)
        else
            stateVoidTrap = false
            if savedPosition then
                myHRP.CFrame = savedPosition
                myHRP.Velocity = Vector3.new(0, 0, 0)
            end
            setSmartFreeze(false)
            BtnVoidTrap.Text = "💀 فخ الفويد + ANTI LAG"
            BtnVoidTrap.BackgroundColor3 = Color3.fromRGB(180, 20, 50)
        end
        return 
    end

    if not targetPlayer or not targetPlayer.Character then targetPlayer = getTarget() end
    
    if targetPlayer and targetPlayer.Character and targetPlayer.Character:FindFirstChild("HumanoidRootPart") then
        local targetHRP = targetPlayer.Character.HumanoidRootPart
        local pos;
        local behindPosition;
        local isRagdoll = isTargetRagdoll(targetPlayer)
        
        local velocity = targetHRP.Velocity
        targetAcceleration = (velocity - lastTargetVelocity) / 0.016
        lastTargetVelocity = velocity
        if targetAcceleration.Magnitude > 150 then targetAcceleration = targetAcceleration.Unit * 150 end
        local predictedVector = velocity * PREDICTION_TIME + 0.5 * targetAcceleration * (PREDICTION_TIME ^ 2)
        
        local currentTargetLook = targetHRP.CFrame.LookVector
        local lastTargetLook = lastTargetCFrame.LookVector
        local angularVelocity = math.acos(math.clamp(currentTargetLook:Dot(lastTargetLook), -1, 1)) / 0.016
        lastTargetCFrame = targetHRP.CFrame
        
        local isSpinningFast = angularVelocity > 12 
        
        ----------------------------------------
        -- [التثبيت العادي]
        ----------------------------------------
        if stateBehind then
            if isSpinningFast then
                behindPosition = targetHRP.Position + Vector3.new(0, -3.5, 0)
                pos = targetHRP.Position
            else
                if isRagdoll then
                    pos = targetHRP.Position
                    local actualGround = getGroundPosition(pos, targetPlayer.Character)
                    behindPosition = actualGround + Vector3.new(0, -1.5, 0)
                else
                    pos = targetHRP.Position + Vector3.new(predictedVector.X, 0, predictedVector.Z)
                    behindPosition = pos + (targetHRP.CFrame.LookVector * -5.0)
                end
            end
            
            setSmartFreeze(true)
            myHRP.CFrame = CFrame.new(behindPosition, pos)

        ----------------------------------------
        -- [التثبيت التدريجي]
        ----------------------------------------
        elseif stateWave then
            if isSpinningFast then
                behindPosition = targetHRP.Position + Vector3.new(0, -3.5, 0)
                pos = targetHRP.Position
            else
                pos = targetHRP.Position + Vector3.new(predictedVector.X, 0, predictedVector.Z)
                loopTime = loopTime + deltaTime * 42 
                local oscillation = (math.sin(loopTime) + 1) / 2 
                local currentDistance = 1.0 + (oscillation * 4.0)
                behindPosition = pos + (targetHRP.CFrame.LookVector * -currentDistance)
            end
            
            setSmartFreeze(true)
            myHRP.CFrame = CFrame.new(behindPosition, pos)
        else
            setSmartFreeze(false)
        end
        
        ----------------------------------------
        -- نظام التحكم الموحد بالكاميرا
        ----------------------------------------
        if stateBehind or stateWave then
            myHumanoid.AutoRotate = false
            Camera.CameraType = Enum.CameraType.Scriptable
            local cameraRotation = CFrame.Angles(0, math.rad(cameraX), 0) * CFrame.Angles(math.rad(cameraY), 0, 0)
            local targetCameraPosition = targetHRP.Position + Vector3.new(0, 2, 0)
            Camera.CFrame = CFrame.new(targetCameraPosition) * cameraRotation * CFrame.new(0, 0, cameraZoom)
        end
    else
        if not stateBehind and not stateWave and Camera.CameraType == Enum.CameraType.Scriptable then
            Camera.CameraType = Enum.CameraType.Custom
            myHumanoid.AutoRotate = true
        end
        setSmartFreeze(false)
    end
end)
